{
  "name": "plataforma-mercado-pago-node",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.ts",
  "scripts": {
    "start": "concurrently \"tsx src/server.ts\" \"npx next start -p 4000\"",
    "build": "npx next build",
    "dev": "concurrently \"tsx src/server.ts\" \"npx next dev -p 4000\"",
    "lint": "eslint \"src/**/*.{ts,tsx}\""
  },
  "dependencies": {
    "@fastify/cors": "^8.3.0",
    "@fastify/static": "^6.10.2",
    "dotenv": "^17.4.2",
    "fastify": "^4.26.2",
    "glob": "^10.3.10"
  },
  "devDependencies": {
    "@types/node": "^20.11.24",
    "@typescript-eslint/eslint-plugin": "^8.65.0",
    "@typescript-eslint/parser": "^8.65.0",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.3",
    "husky": "^9.1.7",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^5.3.3",
    "typescript-eslint": "^7.0.2"
  }
}
